<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.forum.mapper.DailyStatsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.campus.forum.entity.DailyStats">
        <id column="id" property="id"/>
        <result column="stats_date" property="statsDate"/>
        <result column="new_users" property="newUsers"/>
        <result column="active_users" property="activeUsers"/>
        <result column="new_posts" property="newPosts"/>
        <result column="new_comments" property="newComments"/>
        <result column="like_count" property="likeCount"/>
        <result column="collect_count" property="collectCount"/>
        <result column="follow_count" property="followCount"/>
        <result column="view_count" property="viewCount"/>
        <result column="total_users" property="totalUsers"/>
        <result column="total_posts" property="totalPosts"/>
        <result column="total_comments" property="totalComments"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="delete_flag" property="deleteFlag"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, stats_date, new_users, active_users, new_posts, new_comments,
        like_count, collect_count, follow_count, view_count,
        total_users, total_posts, total_comments,
        create_time, update_time, delete_flag
    </sql>

</mapper>
